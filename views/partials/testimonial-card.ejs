<article class="testimonial-card">
  <div class="media-shell no-save" oncontextmenu="return false">
    <a class="media" href="<%= testimonialUrl(item) %>" aria-label="Buka detail testimoni dari @<%= item.username %>">
      <% if (item.mediaType === 'video') { %>
        <video
          src="<%= mediaDisplayUrl(item) %>"
          controls
          controlsList="nodownload noplaybackrate noremoteplayback"
          disablePictureInPicture
          playsinline
          preload="metadata"
          oncontextmenu="return false"
        ></video>
      <% } else { %>
        <img
          src="<%= mediaDisplayUrl(item) %>"
          alt="Testimoni dari @<%= item.username %>"
          loading="lazy"
          draggable="false"
          oncontextmenu="return false"
        >
      <% } %>
    </a>
    <div class="media-badges">
      <span><%= item.mediaType === 'video' ? '▶ Video' : '● Gambar' %></span>
      <span><%= formatNumber(viewCountOf(item)) %> dilihat</span>
    </div>
  </div>
  <div class="content">
    <div class="card-topline">
      <a class="author" href="/@<%= item.username %>">@<%= item.username %></a>
      <time><%= formatDateTime(item.createdAt, config.timezone) %></time>
    </div>
    <p><%= item.text %></p>
    <a class="open-post-link" href="<%= testimonialUrl(item) %>">Buka detail →</a>
    <div class="keywords">
      <% (item.keywords || []).slice(0, 1).forEach((key) => { %>
        <a href="/search?q=<%= encodeURIComponent(key) %>">#<%= key %></a>
      <% }) %>
    </div>
  </div>
</article>
