<form class="search" action="/search" method="get">
  <input
    name="q"
    value="<%= typeof value !== 'undefined' ? value : '' %>"
    placeholder="<%= typeof placeholder !== 'undefined' ? placeholder : 'Cari: testimoni thalassemia' %>"
    autocomplete="off"
  >
  <button type="submit">Cari</button>
</form>
