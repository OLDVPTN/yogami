<% if (!results.length) { %>
  <section class="empty glass-empty">
    <h2>Belum ada hasil.</h2>
    <p>Coba keyword lain yang lebih umum, misalnya “kesehatan”, “produk”, atau “pelayanan”.</p>
  </section>
<% } else { %>
  <section class="cards users">
    <% results.forEach((item) => { %>
      <a class="user-card" href="/@<%= item.username %>">
        <div class="avatar small"><%= (item.name || item.username).charAt(0).toUpperCase() %></div>
        <div class="user-main">
          <div class="user-line">
            <div>
              <h2><%= item.name %><% if (item.verified) { %><span class="verified-badge" title="Akun terverifikasi">✓</span><% } %></h2>
              <p>@<%= item.username %><% if (item.verified) { %> <span class="verified-text">Terverifikasi</span><% } %></p>
            </div>
            <span class="arrow">↗</span>
          </div>
          <div class="stats compact">
            <span><%= formatNumber(item.matchedTestimonials) %> cocok</span>
            <span><%= formatNumber(item.totalTestimonials) %> total</span>
          </div>
          <div class="samples">
            <% item.samples.forEach((sample) => { %>
              <% const sampleText = sample.text || query; %>
              <span><%= sampleText.slice(0, 110) %><%= sampleText.length > 110 ? '…' : '' %></span>
            <% }) %>
          </div>
        </div>
      </a>
    <% }) %>
  </section>
<% } %>
