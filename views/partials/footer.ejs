<footer class="footer">
  <span>Powered by <%= config.botName %></span>
</footer>
<script>
  document.addEventListener('contextmenu', function (event) {
    if (event.target.closest && event.target.closest('.no-save')) event.preventDefault();
  });
  document.addEventListener('dragstart', function (event) {
    if (event.target.closest && event.target.closest('.no-save')) event.preventDefault();
  });

  document.querySelectorAll('[data-load-more]').forEach(function (button) {
    button.addEventListener('click', function () {
      var key = button.getAttribute('data-load-more');
      var step = Number(button.getAttribute('data-step') || 4);
      var grid = document.querySelector('[data-load-grid="' + key + '"]');
      if (!grid) return;
      var hidden = Array.from(grid.querySelectorAll('.testimonial-card.home-hidden'));
      hidden.slice(0, step).forEach(function (card) { card.classList.remove('home-hidden'); });
      if (grid.querySelectorAll('.testimonial-card.home-hidden').length === 0) {
        button.closest('.load-more-wrap')?.remove();
      }
    });
  });
</script>
</body>
</html>
