<% if (!testimonials || !testimonials.length) { %>
  <section class="empty glass-empty">
    <h2>Belum ada testimoni.</h2>
    <p>Testimoni yang dikirim lewat WhatsApp akan muncul di sini.</p>
  </section>
<% } else { %>
  <section class="cards testimonials <%= typeof homeLimit !== 'undefined' ? 'home-testimonial-grid' : '' %>">
    <% testimonials.forEach((item, index) => { %>
      <%- include('testimonial-card', { item, config, cardClass: (typeof homeLimit !== 'undefined' && index >= homeLimit) ? 'home-hidden' : '' }) %>
    <% }) %>
  </section>
  <% if (typeof homeLimit !== 'undefined' && testimonials.length > homeLimit) { %>
    <div class="load-more-wrap">
      <button class="load-more-btn" type="button" data-load-more="home-testimonials" data-step="4">Load more</button>
    </div>
  <% } %>
<% } %>
