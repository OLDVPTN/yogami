<%- include('../partials/head') %>
<%- include('../partials/topbar') %>

<main class="container">
  <section class="detail-layout">
    <article class="detail-main panel">
      <div class="detail-media-frame no-save" oncontextmenu="return false">
        <div class="detail-media">
          <% if (testimonial.mediaType === 'video') { %>
            <video
              src="<%= mediaDisplayUrl(testimonial) %>"
              controls
              controlsList="nodownload noplaybackrate noremoteplayback nofullscreen"
              disablePictureInPicture
              playsinline
              preload="metadata"
              oncontextmenu="return false"
            ></video>
          <% } else { %>
            <img
              src="<%= mediaDisplayUrl(testimonial) %>"
              alt="Testimoni dari @<%= testimonial.username %>"
              loading="eager"
              draggable="false"
              oncontextmenu="return false"
            >
          <% } %>

          <% const wmHashtag = (testimonial.keywords || ['testimoni'])[0] || 'testimoni'; %>
          <% const wmTop = `@${testimonial.username} • #${wmHashtag}`; %>
          <% const wmBottomLeft = config.webTitle || 'Poko Testimoni'; %>
          <% const wmBottomRight = formatDateTime(testimonial.createdAt, config.timezone); %>
          <% if (!testimonial.watermarked || testimonial.mediaType === 'video') { %>
            <div class="display-watermark" aria-hidden="true">
              <div class="wm-topbar"><span><%= wmTop %></span></div>
              <div class="wm-bottombar"><strong><%= wmBottomLeft %></strong><span><%= wmBottomRight %></span></div>
            </div>
          <% } %>

          <div class="detail-badges">
            <span><%= mediaKindLabel(testimonial) %></span>
            <span><%= formatNumber(viewCountOf(testimonial)) %> dilihat</span>
          </div>
        </div>
      </div>
    </article>

    <aside class="detail-sidebar panel">
      <div class="detail-author">
        <div class="avatar"><%= ((member?.name || testimonial.memberName || testimonial.username) || 'M').charAt(0).toUpperCase() %></div>
        <div>
          <p class="eyebrow">Testimoni Member</p>
          <h1 class="detail-title"><%= member?.name || testimonial.memberName || testimonial.username %></h1>
          <p class="username">@<%= testimonial.username %></p>
        </div>
      </div>

      <div class="detail-meta">
        <a class="detail-hashtag" href="/search?q=<%= encodeURIComponent((testimonial.keywords || [''])[0] || '') %>">#<%= (testimonial.keywords || [''])[0] || 'testimoni' %></a>
        <time><%= formatDateTime(testimonial.createdAt, config.timezone) %></time>
      </div>

      <div class="detail-caption">
        <p><%= testimonial.text %></p>
      </div>

      <div class="detail-stat-grid">
        <div><span>Dilihat</span><strong><%= formatNumber(viewCountOf(testimonial)) %></strong></div>
        <div><span>Tipe</span><strong><%= mediaKindLabel(testimonial) %></strong></div>
        <div><span>Profil</span><strong>@<%= testimonial.username %></strong></div>
      </div>

      <div class="detail-actions">
        <a class="primary-btn" href="/@<%= testimonial.username %>">Lihat Profil</a>
        <a class="secondary-btn" href="/search?q=<%= encodeURIComponent((testimonial.keywords || [''])[0] || '') %>">Cari Hashtag</a>
      </div>

      <p class="muted small-note">Gambar baru otomatis diberi watermark permanen model atas–bawah sebelum masuk storage. Video memakai watermark display atas–bawah, kecuali kamu mengaktifkan embedded video watermark lewat env.</p>
    </aside>
  </section>

  <section class="section-head">
    <div>
      <p class="eyebrow">Lainnya dari @<%= testimonial.username %></p>
      <h2>Testimoni terkait</h2>
    </div>
    <a class="text-link" href="/@<%= testimonial.username %>">Buka profil</a>
  </section>

  <%- include('../partials/testimonial-grid', { testimonials: related, config }) %>
</main>

<%- include('../partials/footer') %>
