<%- include('../partials/head') %>
<%- include('../partials/topbar') %>

<main class="container">
  <section class="hero hero-home">
    <div class="hero-copy">
      <p class="eyebrow">Poko Member Stories</p>
      <h1>Cari testimoni asli dari member.</h1>
      <p class="lead">Temukan pengalaman member berdasarkan keyword. Buka profil pengguna, lihat gambar atau video testimoni, lalu bandingkan pengalaman yang paling relevan.</p>
      <%- include('../partials/search-form', { value: query }) %>
      <div class="hero-stats" aria-label="Statistik platform">
        <span><strong><%= formatNumber(stats?.testimonials || 0) %></strong> Testimoni</span>
        <span><strong><%= formatNumber(stats?.members || 0) %></strong> Member</span>
        <span><strong><%= formatNumber(stats?.views || 0) %></strong> Dilihat</span>
      </div>
    </div>
    <div class="hero-card" aria-hidden="true">
      <div class="hero-orb"></div>
      <p><%= trendingKeyword?.source === 'today-search' ? 'Paling dicari hari ini' : 'Keyword yang bisa dicari' %></p>
      <strong>#<%= trendingKeyword?.label || 'thalasemia' %></strong>
      <span>
        <% if (trendingKeyword?.source === 'today-search') { %>
          <%= formatNumber(trendingKeyword.count || 0) %>x dicari hari ini
        <% } else { %>
          Gambar · Video · Profil Member
        <% } %>
      </span>
    </div>
  </section>

  <% if (verified && verified.length) { %>
    <section class="section-head">
      <div>
        <p class="eyebrow">Terverifikasi</p>
        <h2>Testimoni terverifikasi</h2>
      </div>
      <span class="section-note">Dipilih dan dicek oleh tim</span>
    </section>

    <%- include('../partials/testimonial-grid', { testimonials: verified, config, homeLimit: 4, loadMoreKey: 'verified-testimonials' }) %>
  <% } %>

  <section class="section-head">
    <div>
      <p class="eyebrow">Terbaru</p>
      <h2>Testimoni terbaru</h2>
    </div>
    <a class="text-link" href="/latest">Lihat semua</a>
  </section>

  <%- include('../partials/testimonial-grid', { testimonials: latest, config, homeLimit: 4, loadMoreKey: 'latest-testimonials' }) %>
</main>

<%- include('../partials/footer') %>
