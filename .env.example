# Website public URL
PUBLIC_BASE_URL=https://yogami.onrender.com
PORT=10000
OWNER_NUMBER=628xxxxxxxxxx

# Meta WhatsApp Cloud API Official
GRAPH_API_VERSION=v25.0
WHATSAPP_ACCESS_TOKEN=EAAGxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=buat_token_random_sendiri_misal_poko_webhook_2026
WHATSAPP_WEBHOOK_PATH=/webhook
# Opsional tapi disarankan untuk validasi signature webhook
META_APP_SECRET=isi_app_secret_meta

# Database: neon atau local
# local = database/database.json, neon = Neon PostgreSQL relational tables
DB_PROVIDER=neon
# Pakai pooled connection string dari Neon, biasanya host-nya mengandung -pooler
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require
DB_STATE_KEY=main
DB_SAVE_DEBOUNCE_MS=1500
DB_POOL_MAX=5

# Storage: r2 atau local
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=isi_account_id_cloudflare
R2_ACCESS_KEY_ID=isi_access_key_id_r2
R2_SECRET_ACCESS_KEY=isi_secret_access_key_r2
R2_BUCKET=poko-testimoni
# Mode rekomendasi: proxy. Media diakses lewat domain web kamu (/media/:id), bucket R2 tetap private.
# Pakai public hanya kalau kamu benar-benar sudah punya custom domain R2 yang aman.
MEDIA_SERVE_MODE=proxy
R2_PUBLIC_BASE_URL=
R2_UPLOAD_PREFIX=testimonials


# Watermark rekomendasi
# top-bottom = watermark atas dan bawah, lebih aman dari crop dibanding badge pojok.
WATERMARK_MODE=both
WATERMARK_LAYOUT=top-bottom
WATERMARK_EMBED_IMAGES=true
WATERMARK_EMBED_VIDEOS=false
WATERMARK_OPACITY=0.72
# Opsional, bisa pakai placeholder: {username}, {hashtag}, {site}, {datetime}
WATERMARK_TOP_TEXT={username} • {hashtag}
WATERMARK_BOTTOM_LEFT={site}
WATERMARK_BOTTOM_RIGHT={datetime}
